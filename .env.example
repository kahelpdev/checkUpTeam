# Intervalo de ingestion em minutos (padrão: 5)
INGESTION_INTERVAL_MINUTES=5

# Google Gemini AI
GEMINI_API_KEY=""

# Autenticação JWT — gerar com: openssl rand -base64 48
AUTH_SECRET=""
AUTH_PASSWORD=""

# Telegram Bot (alertas)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# cardsFlow API (NSSCardFlow)
FLOW_API_BASE_URL=""
FLOW_API_EMAIL=""
FLOW_API_PASSWORD=""
