# Banco de dados do CheckUpTeam (Postgres)
DATABASE_URL="postgresql://USER:PASS@HOST:5432/checkupteam"

# API do cardsFlow (read-only, via PostgREST)
CARDFLOW_API_URL="http://HOST:3001"
